default_platform(:ios)

platform :ios do
  desc "Push a new beta build to TestFlight"
  lane :beta do
    build_ios_app(
      scheme: "Runner",
      workspace: "ios/Runner.xcworkspace",
      export_method: "app-store"
    )
    upload_to_testflight
  end

  desc "Push a new release build to the App Store"
  lane :release do
    build_ios_app(
      scheme: "Runner",
      workspace: "ios/Runner.xcworkspace",
      export_method: "app-store"
    )
    upload_to_app_store
  end

  desc "Sync code signing certificates and provisioning profiles"
  lane :sync_signing do
    match(type: "appstore", readonly: is_ci)
  end
end

platform :android do
  desc "Build a debug APK"
  lane :build_debug do
    gradle(
      task: "assemble",
      build_type: "Debug",
      project_dir: "android/"
    )
  end

  desc "Build a release APK"
  lane :build_release do
    gradle(
      task: "assemble",
      build_type: "Release",
      project_dir: "android/"
    )
  end

  desc "Upload to Google Play internal track"
  lane :beta do
    gradle(
      task: "bundle",
      build_type: "Release",
      project_dir: "android/"
    )
    upload_to_play_store(track: "internal")
  end
end
