# fastlane/Fastfile
# Manages code signing (via match) and App Store Connect upload

default_platform(:ios)

platform :ios do

  # ── App identity ─────────────────────────────────────────────────────────────
  APP_IDENTIFIER = "inventree.inventree_app"   # Change if your bundle ID differs
  TEAM_ID        = ENV["APPLE_TEAM_ID"]        # Set in GitHub Secrets

  # ── App Store Connect API key (used instead of password) ─────────────────────
  def asc_api_key
    app_store_connect_api_key(
      key_id:      ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id:   ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      is_key_content_base64: false,
      in_house: false
    )
  end

  # ── Lane: sync_signing ────────────────────────────────────────────────────────
  # Fetches/creates certificates and provisioning profiles via match.
  # Your certs repo is a *private* GitHub repo you create once (see SETUP.md).
  desc "Sync code signing certificates and profiles"
  lane :sync_signing do |options|
    match(
      type:              "appstore",
      app_identifier:    APP_IDENTIFIER,
      team_id:           TEAM_ID,
      git_url:           ENV["MATCH_GIT_URL"],
      readonly:          options.fetch(:readonly, true),
      api_key:           asc_api_key
    )
  end

  # ── Lane: deploy ──────────────────────────────────────────────────────────────
  # Uploads the already-built .ipa to TestFlight.
  desc "Upload .ipa to TestFlight"
  lane :deploy do
    api_key = asc_api_key

    # Find the .ipa built by `flutter build ipa`
    ipa_path = Dir["../build/ios/ipa/*.ipa"].first
    UI.user_error!("No .ipa found. Did `flutter build ipa` run?") unless ipa_path

    upload_to_testflight(
      api_key:              api_key,
      ipa:                  ipa_path,
      skip_waiting_for_build_processing: true,  # Don't block CI; processing happens async
      distribute_external:  false,              # Internal testers only (change if needed)
      notify_external_testers: false
    )

    UI.success("Successfully uploaded to TestFlight!")
  end

  # ── Lane: full_deploy ─────────────────────────────────────────────────────────
  # One-shot lane: sign + build + upload. Useful for local runs.
  desc "Full local deploy: sign, build, upload"
  lane :full_deploy do
    sync_signing(readonly: false)
    sh("cd .. && flutter build ipa --release --export-options-plist=ios/ExportOptions.plist")
    deploy
  end

end
